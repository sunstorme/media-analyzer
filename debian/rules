#!/usr/bin/make -f
include /usr/share/dpkg/default.mk

# Detect available Qt versions
QT5_AVAILABLE := $(shell pkg-config --exists Qt5Core && echo yes)
QT6_AVAILABLE := $(shell pkg-config --exists Qt6Core && echo yes)

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	# Prefer Qt6, fallback to Qt5
	if [ -n "$(QT6_AVAILABLE)" ]; then \
		mkdir -p build; \
		cmake -S . -B build \
			-DCMAKE_INSTALL_PREFIX=/usr \
			-DCMAKE_BUILD_TYPE=Release \
			-DQT_MAJOR_VERSION=6 \
			-DCMAKE_INSTALL_BINDIR=bin \
			-DCMAKE_INSTALL_LIBDIR=lib/x86_64-linux-gnu \
			-DCMAKE_INSTALL_INCLUDEDIR=include; \
	elif [ -n "$(QT5_AVAILABLE)" ]; then \
		mkdir -p build; \
		cmake -S . -B build \
			-DCMAKE_INSTALL_PREFIX=/usr \
			-DCMAKE_BUILD_TYPE=Release \
			-DQT_MAJOR_VERSION=5 \
			-DCMAKE_INSTALL_BINDIR=bin \
			-DCMAKE_INSTALL_LIBDIR=lib/x86_64-linux-gnu \
			-DCMAKE_INSTALL_INCLUDEDIR=include; \
	else \
		echo "Error: Neither Qt5 nor Qt6 is available"; \
		exit 1; \
	fi

override_dh_auto_build:
	# Build the configured version
	cmake --build build --parallel 16

override_dh_auto_install:
	# Install the configured version
	DESTDIR=debian/media-analyzer cmake --install build

override_dh_clean:
	dh_clean
	rm -rf build

override_dh_auto_test:
	# Skip tests as there are no test targets defined

	dh_install
	
print-qt-versions:
	@echo "Qt5 available: $(QT5_AVAILABLE)"
	@echo "Qt6 available: $(QT6_AVAILABLE)"
